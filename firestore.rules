rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global safety net catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Entity validator: UserProfile
    function isValidUserProfile(data) {
      return data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.role is string && (data.role == 'citizen' || data.role == 'admin') &&
             data.coins is number && data.coins >= 0 &&
             data.createdAt is number;
    }

    // Entity validator: Report
    function isValidReport(data) {
      return data.type is string && (data.type == 'pothole' || data.type == 'drainage' || data.type == 'waste' || data.type == 'hazard') &&
             data.severity is string && (data.severity == 'low' || data.severity == 'medium' || data.severity == 'high') &&
             data.status is string && (data.status == 'pending' || data.status == 'in-progress' || data.status == 'resolved') &&
             data.location is map &&
             data.location.lat is number &&
             data.location.lng is number &&
             data.location.address is string && data.location.address.size() <= 500 &&
             data.reporterId is string && data.reporterId.size() <= 128 &&
             data.description is string && data.description.size() <= 2000 &&
             data.tags is list && data.tags.size() <= 10 &&
             data.comments is list && data.comments.size() <= 200 &&
             (!data.keys().hasAny(['imageUrl']) || (data.imageUrl is string && data.imageUrl.size() <= 1000));
    }

    // Collection: Users
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isOwner(userId) && isValidUserProfile(incoming()) && (incoming().role == 'citizen');
      allow update: if isSignedIn() && (
        (isOwner(userId) && isValidUserProfile(incoming()) && incoming().role == existing().role && incoming().role == 'citizen' && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'coins'])) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Collection: Reports
    match /reports/{reportId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(reportId) && isValidReport(incoming()) && (incoming().reporterId == request.auth.uid) && incoming().createdAt == request.time && incoming().updatedAt == request.time;
      allow update: if isSignedIn() && isValidId(reportId) && (
        isValidReport(incoming()) && 
        incoming().createdAt == existing().createdAt &&
        incoming().updatedAt == request.time && (
          existing().status != 'resolved' || isAdmin()
        ) && (
          // Admin can modify any fields
          isAdmin() ||
          // Citizen can only modify comments or update timestamp
          (incoming().diff(existing()).affectedKeys().hasOnly(['comments', 'updatedAt']))
        )
      );
      allow delete: if isAdmin();
    }
  }
}
